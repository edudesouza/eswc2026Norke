<https://omc.co/5511993891773/7492/Chapter_VII/Article_70/Point_1q>
                    a v:Point ;            
                    v:fullText "provide the Commission with an opinion on the certification requirements referred to in Article 43(8);"@en ;
                    v:breadcrumb        "chapter VII, article 70, point 1q"@en ;
                    v:breadcrumbLabel   "chapter VII (Cooperation and consistency), article 70 (Tasks of the Board), point 1q"@en ;
                    v:isPartOfArticle <https://omc.co/5511993891773/7492/Chapter_VII/Article_70>;  
