<https://omc.co/5511993891773/7492/Chapter_VII/Article_70/Point_1o>
                    a v:Point ;            
                    v:fullText "carry out the accreditation of certification bodies and its periodic review pursuant to Article 43 and maintain a public register of accredited bodies pursuant to Article 43(6) and of the accredited controllers or processors established in third countries pursuant to Article 42(7);"@en ;
                    v:breadcrumb        "chapter VII, article 70, point 1o"@en ;
                    v:breadcrumbLabel   "chapter VII (Cooperation and consistency), article 70 (Tasks of the Board), point 1o"@en ;
                    v:isPartOfArticle <https://omc.co/5511993891773/7492/Chapter_VII/Article_70>;  
