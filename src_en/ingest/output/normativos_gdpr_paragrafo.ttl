<https://omc.co/5511993891773/7492/Chapter_VII/Article_70/Point_1p>
                    a v:Point ;            
                    v:fullText "specify the requirements referred to in Article 43(3) with a view to the accreditation of certification bodies under Article 42;"@en ;
                    v:breadcrumb        "chapter VII, article 70, point 1p"@en ;
                    v:breadcrumbLabel   "chapter VII (Cooperation and consistency), article 70 (Tasks of the Board), point 1p"@en ;
