    rdfs:domain :Titular ;
    rdfs:range xsd:string .

:rg a owl:DatatypeProperty ;
    rdfs:label "rg"@pt ;
    rdfs:comment "Registro Geral da pessoa natural."@pt ;
    rdfs:domain :Titular ;
    rdfs:range xsd:string .

:cpf a owl:DatatypeProperty ;
    rdfs:label "cpf"@pt ;
    rdfs:comment "Cadastro de Pessoa Física."@pt ;
    rdfs:domain :Titular ;
    rdfs:range xsd:string .

:cnpj a owl:DatatypeProperty ;
    rdfs:label "cnpj"@pt ;
    rdfs:comment "Cadastro Nacional da Pessoa Jurídica."@pt ;
    rdfs:domain :EntidadePrivada ;
    rdfs:range xsd:string .

:data a owl:DatatypeProperty ;
    rdfs:label "data"@pt ;
    rdfs:comment "Data associada a evento, documento, operação ou sanção."@pt ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:date .

:texto a owl:DatatypeProperty ;
    rdfs:label "texto"@pt ;
    rdfs:comment "Texto literal associado a entidade, documento ou norma."@pt ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

:descricao a owl:DatatypeProperty ;
    rdfs:label "descrição"@pt ;
    rdfs:comment "Descrição textual detalhada de uma entidade ou relação."@pt ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

:conteudo a owl:DatatypeProperty ;
    rdfs:label "conteúdo"@pt ;
    rdfs:comment "Conteúdo textual integral ou parcial de documento, chunk ou registro."@pt ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

:arquivo a owl:DatatypeProperty ;
